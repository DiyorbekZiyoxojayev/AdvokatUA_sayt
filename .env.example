# ════════════════════════════════════════════════
#  AdvokatUA — Environment Variables
#  Bu faylni nusxalab .env deb saqlang
#  .env faylini hech qachon Git ga commit qilmang!
# ════════════════════════════════════════════════

# Anthropic API kaliti (https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Server port (default: 3000)
PORT=3000

# Production yoki development
NODE_ENV=development

# Saytingizning asosiy domenini yozing (vergul bilan ajrating)
# Masalan: https://advokatua.uz,https://www.advokatua.uz
ALLOWED_ORIGINS=http://localhost:3000
